    def run(self) -> int:
        self.validate_common()

        for spec in self.tree_specs:
            self.load_tree(spec, from_deletions=False)
            self.load_tree(spec, from_deletions=True)

        self.validate_bootstrap()
        self.validate_network()
        self.validate_system()
        self.validate_ha()
        self.validate_tls()
        self.validate_ltm()
        self.validate_gtm()
        self.validate_security()
        self.validate_waf()
        self.validate_apm()

        if self.errors:
            for error in self.errors:
                print(f"ERROR: {error}", file=sys.stderr)
            print(f"Validation failed with {len(self.errors)} error(s).", file=sys.stderr)
            return 1

        print("Validation passed.")
        return 0

    def validate_common(self) -> None:
        path = VARS_DIR / "common.yml"
        payload = self.load_yaml(path)
        if not isinstance(payload, dict):
            self.error(path, "must contain a mapping")
            return
        if "provider" not in payload:
            self.error(path, "must define `provider`")
        elif not isinstance(payload["provider"], dict):
            self.error(path, "`provider` must be a mapping")

    def validate_bootstrap(self) -> None:
        licenses = self.objects.get("bootstrap_licenses", [])
        management = self.objects.get("bootstrap_management", [])

        for obj in licenses:
            if obj.from_deletions:
                self.error(obj.relpath, "bootstrap license objects do not support deletion trees")
                continue
            state = str(obj.data.get("state", "present"))
            if state not in ("present", "latest", "absent", "revoked"):
                self.error(obj.relpath, f"bootstrap license state `{state}` is unsupported")
            if state in ("present", "latest"):
                self.require_fields(obj, ["license_key"])
                if obj.data.get("accept_eula") is not True:
                    self.error(obj.relpath, "bootstrap license objects using `present` or `latest` must set `accept_eula: true`")
            addon_keys = obj.data.get("addon_keys")
            if addon_keys is not None and not isinstance(addon_keys, list):
                self.error(obj.relpath, "`addon_keys` must be a list when provided")

        self.check_duplicates(
            licenses,
            lambda obj: ("bootstrap_license", obj.data.get("license_key") or obj.relpath, obj.data.get("state", "present")),
            "bootstrap license object",
        )

        for obj in management:
            if obj.from_deletions:
                self.error(obj.relpath, "bootstrap management objects do not support deletion trees")
                continue
            self.require_fields(obj, ["address", "gateway"])
            try:
                ipaddress.ip_interface(str(obj.data.get("address")))
            except ValueError:
                self.error(obj.relpath, f"bootstrap management address `{obj.data.get('address')}` must be a valid CIDR")
            try:
                ipaddress.ip_address(str(obj.data.get("gateway")))
            except ValueError:
                self.error(obj.relpath, f"bootstrap management gateway `{obj.data.get('gateway')}` must be a valid IP address")
            route_name = obj.data.get("route_name")
            if route_name is not None and str(route_name).strip() == "":
                self.error(obj.relpath, "bootstrap management `route_name` may not be empty")

        self.check_duplicates(
            management,
            lambda obj: ("bootstrap_management", obj.data.get("route_name", "default")),
            "bootstrap management route",
        )

    def load_tree(self, spec: TreeSpec, *, from_deletions: bool) -> None:
        base_dir = spec.deletion_dir if from_deletions else spec.active_dir
        if not base_dir.exists():
            return

        for path in sorted(base_dir.rglob("*.yml")):
            if path.name == "settings.yml":
                self.validate_settings_file(path, spec)
                continue

            payload = self.load_yaml(path)
            if not isinstance(payload, dict):
                self.error(path, "must contain a mapping")
                continue

            unknown = sorted(set(payload) - {spec.top_key})
            if unknown:
                self.error(path, f"contains unsupported keys: {', '.join(unknown)}")

            entries = payload.get(spec.top_key)
            if entries is None:
                self.error(path, f"must define `{spec.top_key}`")
                continue
            if not isinstance(entries, list):
                self.error(path, f"`{spec.top_key}` must be a list")
                continue

            defaults = self.load_directory_defaults(path.parent / "settings.yml", spec)
            for index, entry in enumerate(entries):
                if not isinstance(entry, dict):
                    self.error(path, f"`{spec.top_key}[{index}]` must be a mapping")
                    continue
                if from_deletions and "state" in entry and entry["state"] != "absent":
                    self.error(path, f"`{spec.top_key}[{index}]` in deletions may only use `state: absent`")
                self.objects.setdefault(spec.name, []).append(
                    LoadedObject(
                        tree=spec,
                        source_file=path,
                        defaults=defaults,
                        data=entry,
                        from_deletions=from_deletions,
                    )
                )

    def validate_settings_file(self, path: Path, spec: TreeSpec) -> None:
        payload = self.load_yaml(path)
        if not isinstance(payload, dict):
            self.error(path, "must contain a mapping")
            return

        allowed_keys = {spec.settings_key, *spec.extra_settings_keys}
        unknown = sorted(set(payload) - allowed_keys)
        if unknown:
            self.error(path, f"contains unsupported keys: {', '.join(unknown)}")

        defaults = payload.get(spec.settings_key)
        if defaults is not None and not isinstance(defaults, dict):
            self.error(path, f"`{spec.settings_key}` must be a mapping")

    def load_directory_defaults(self, path: Path, spec: TreeSpec) -> dict[str, Any]:
        if not path.exists():
            return {}
        payload = self.load_yaml(path)
        if not isinstance(payload, dict):
            return {}
        defaults = payload.get(spec.settings_key, {})
        return defaults if isinstance(defaults, dict) else {}

    def load_settings_payload(self, path: Path) -> dict[str, Any]:
        if path in self.settings_cache:
            return self.settings_cache[path]
        if not path.exists():
            self.settings_cache[path] = {}
            return {}
        payload = self.load_yaml(path)
        if not isinstance(payload, dict):
            self.settings_cache[path] = {}
            return {}
        self.settings_cache[path] = payload
        return payload

    def validate_network(self) -> None:
        vlans = self.objects.get("network_vlans", [])
        self_ips = self.objects.get("network_self_ips", [])
        route_domains = self.objects.get("network_route_domains", [])
        routes = self.objects.get("network_routes", [])
        snat_translations = self.objects.get("network_snat_translations", [])
        snat_pools = self.objects.get("network_snat_pools", [])
        trunks = self.objects.get("network_trunks", [])
        nats = self.objects.get("network_nats", [])

        active_vlan_names = set()

        for obj in vlans:
            self.require_fields(obj, ["name"])
            if obj.effective_state != "absent":
                active_vlan_names.add(self.fq_name(obj.partition, str(obj.data["name"])))
                interfaces = obj.data.get("interfaces")
                if interfaces is not None and not isinstance(interfaces, list):
                    self.error(obj.relpath, "`interfaces` must be a list")

        active_route_domain_ids = {0}

        for obj in route_domains:
            if obj.effective_state == "absent":
                continue
            route_domain_id = obj.data.get("id")
            if isinstance(route_domain_id, int):
                active_route_domain_ids.add(route_domain_id)

        for obj in route_domains:
            self.require_fields(obj, ["name"])
            if obj.effective_state == "absent":
                continue
            self.require_fields(obj, ["id"])
            route_domain_id = obj.data.get("id")
            if route_domain_id is not None:
                if not isinstance(route_domain_id, int):
                    self.error(obj.relpath, f"route domain `{obj.data.get('name')}` `id` must be an integer")
            vlans_list = obj.data.get("vlans")
            if vlans_list is not None and not isinstance(vlans_list, list):
                self.error(obj.relpath, f"route domain `{obj.data.get('name')}` `vlans` must be a list")
            for vlan in vlans_list or []:
                self.validate_named_or_fq_reference(
                    obj.relpath,
                    vlan,
                    obj.partition,
                    active_vlan_names,
                    "route domain VLAN",
                )
            routing_protocol = obj.data.get("routing_protocol")
            if routing_protocol is not None and not isinstance(routing_protocol, list):
                self.error(obj.relpath, f"route domain `{obj.data.get('name')}` `routing_protocol` must be a list")
            parent = obj.data.get("parent")
            if parent not in (None, ""):
                parent_id = self.normalize_route_domain_id(parent)
                if parent_id is None:
                    self.error(obj.relpath, f"route domain `{obj.data.get('name')}` `parent` must be an integer route domain ID")

        for obj in self_ips:
            self.require_fields(obj, ["name"])
            if obj.effective_state != "absent":
                self.require_fields(obj, ["address", "netmask", "vlan"])
                self.validate_named_or_fq_reference(
                    obj.relpath,
                    obj.data.get("vlan"),
                    obj.partition,
                    active_vlan_names,
                    "self IP VLAN",
                )
                route_domain_id = self.extract_route_domain_id(obj.data.get("address"))
                if route_domain_id is not None and route_domain_id not in active_route_domain_ids:
                    self.error(obj.relpath, f"self IP `{obj.data.get('name')}` references undefined route domain `{route_domain_id}` in `address`")

        active_snat_translation_names = set()

        for obj in snat_translations:
            self.require_fields(obj, ["name"])
            if obj.effective_state != "absent":
                self.require_fields(obj, ["address"])
                active_snat_translation_names.add(self.fq_name(obj.partition, str(obj.data["name"])))

        for obj in snat_pools:
            self.require_fields(obj, ["name"])
            if obj.effective_state == "absent":
                continue
            members = obj.data.get("members")
            if not isinstance(members, list) or not members:
                self.error(obj.relpath, f"SNAT pool `{obj.data.get('name')}` must define a non-empty `members` list")
                continue
            for member in members:
                if not isinstance(member, str):
                    self.error(obj.relpath, f"SNAT pool `{obj.data.get('name')}` member references must be strings")
                    continue
                if self.is_ip_address(member):
                    continue
                self.validate_named_or_fq_reference(
                    obj.relpath,
                    member,
                    obj.partition,
                    active_snat_translation_names,
                    "SNAT pool member",
                )

        for obj in routes:
            self.require_fields(obj, ["name"])
            if obj.effective_state == "absent":
                continue
            self.require_fields(obj, ["destination", "netmask"])
            if not any(obj.data.get(field) not in (None, "") for field in ("gateway_address", "pool")) and not bool(obj.data.get("reject")):
                self.error(obj.relpath, f"static route `{obj.data.get('name')}` must define `gateway_address`, `pool`, or `reject: true`")
            if obj.data.get("vlan") is not None:
                self.validate_named_or_fq_reference(
                    obj.relpath,
                    obj.data.get("vlan"),
                    obj.partition,
                    active_vlan_names,
                    "static route VLAN",
                )
            route_domain = obj.data.get("route_domain")
            if route_domain is not None:
                if not isinstance(route_domain, int):
                    self.error(obj.relpath, f"static route `{obj.data.get('name')}` `route_domain` must be an integer")
                elif route_domain not in active_route_domain_ids:
                    self.error(obj.relpath, f"static route `{obj.data.get('name')}` references undefined route domain `{route_domain}`")

        for obj in trunks:
            self.require_fields(obj, ["name"])
            if obj.effective_state == "absent":
                continue
            interfaces = obj.data.get("interfaces")
            if not isinstance(interfaces, list) or not interfaces:
                self.error(obj.relpath, f"trunk `{obj.data.get('name')}` must define a non-empty `interfaces` list")
            if obj.data.get("lacp_enabled") is False and obj.data.get("lacp_mode") not in (None, ""):
                self.error(obj.relpath, f"trunk `{obj.data.get('name')}` sets `lacp_mode` while `lacp_enabled` is false")
            if obj.data.get("lacp_enabled") is False and obj.data.get("lacp_timeout") not in (None, ""):
                self.error(obj.relpath, f"trunk `{obj.data.get('name')}` sets `lacp_timeout` while `lacp_enabled` is false")

        for obj in nats:
            self.require_fields(obj, ["name"])
            if obj.effective_state == "absent":
                continue
            self.require_fields(obj, ["originating_address", "translation_address"])
            nat_vlans = obj.data.get("vlans")
            if nat_vlans is not None and not isinstance(nat_vlans, list):
                self.error(obj.relpath, f"NAT `{obj.data.get('name')}` `vlans` must be a list")
            for vlan in nat_vlans or []:
                self.validate_named_or_fq_reference(
                    obj.relpath,
                    vlan,
                    obj.partition,
                    active_vlan_names,
                    "NAT VLAN",
                )

        self.check_duplicates(vlans, lambda obj: ("vlan", obj.partition, obj.data.get("name")), "VLAN")
        self.check_duplicates(route_domains, lambda obj: ("route_domain", obj.partition, obj.data.get("name")), "route domain")
        self.check_duplicates(
            route_domains,
            lambda obj: ("route_domain_id", obj.data.get("id")),
            "route domain ID",
        )
        self.check_duplicates(self_ips, lambda obj: ("self_ip", obj.partition, obj.data.get("name")), "self IP")
        self.check_duplicates(routes, lambda obj: ("static_route", obj.partition, obj.data.get("name")), "static route")
        self.check_duplicates(
            snat_translations,
            lambda obj: ("snat_translation", obj.partition, obj.data.get("name")),
            "SNAT translation",
        )
        self.check_duplicates(snat_pools, lambda obj: ("snat_pool", obj.partition, obj.data.get("name")), "SNAT pool")
        self.check_duplicates(trunks, lambda obj: ("trunk", obj.data.get("name")), "trunk")
        self.check_duplicates(nats, lambda obj: ("nat", obj.partition, obj.data.get("name")), "NAT")

    def validate_system(self) -> None:
        hostnames = self.objects.get("system_hostnames", [])
        dns_settings = self.objects.get("system_dns", [])
        ntp_settings = self.objects.get("system_ntp", [])
        provisioning = self.objects.get("system_provisioning", [])
        users = self.objects.get("system_users", [])
        auth_ldap = self.objects.get("system_auth_ldap", [])
        auth_tacacs = self.objects.get("system_auth_tacacs", [])
        auth_radius_servers = self.objects.get("system_auth_radius_servers", [])
        auth_radius = self.objects.get("system_auth_radius", [])
        login_banners = self.objects.get("system_login_banners", [])
        config = self.objects.get("system_config", [])

        for obj in hostnames:
            if obj.effective_state != "absent":
                self.require_fields(obj, ["hostname"])

        for obj in dns_settings:
            if obj.effective_state != "absent":
                if not obj.data.get("name_servers") and not obj.data.get("search") and obj.data.get("cache") is None and obj.data.get("ip_version") is None:
                    self.error(obj.relpath, "system DNS object must define at least one of `name_servers`, `search`, `cache`, or `ip_version`")

        for obj in ntp_settings:
            if obj.effective_state != "absent":
                if not obj.data.get("ntp_servers") and not obj.data.get("timezone"):
                    self.error(obj.relpath, "system NTP object must define `ntp_servers` or `timezone`")

        for obj in provisioning:
            self.require_fields(obj, ["module"])
            if obj.effective_state != "absent" and obj.data.get("module") != "mgmt" and not obj.data.get("level"):
                self.error(obj.relpath, f"system provisioning module `{obj.data.get('module')}` should define `level`")

        self.check_duplicates(
            provisioning,
            lambda obj: ("system_provisioning", obj.data.get("module")),
            "system provisioning module",
        )

        for obj in users:
            self.require_fields(obj, ["name"])
            if obj.effective_state != "absent":
                if obj.data.get("name") != "root" and not obj.data.get("partition_access"):
                    self.error(obj.relpath, f"system user `{obj.data.get('name')}` must define `partition_access`")
                if obj.data.get("state", "present") == "present" and obj.data.get("password_credential") is None and obj.data.get("update_password") == "on_create":
                    self.error(obj.relpath, f"system user `{obj.data.get('name')}` uses `update_password: on_create` without `password_credential`")

        self.check_duplicates(users, lambda obj: ("system_user", obj.data.get("name")), "system user")

        active_radius_server_names = set()
        for obj in auth_radius_servers:
            self.require_fields(obj, ["name"])
            if obj.effective_state == "absent":
                continue

            self.require_fields(obj, ["ip"])
            self.validate_ip_like(obj.relpath, obj.data.get("ip"), f"system RADIUS server `{obj.data.get('name')}` `ip`")

            port = obj.data.get("port")
            if port is not None:
                if not isinstance(port, int):
                    self.error(obj.relpath, f"system RADIUS server `{obj.data.get('name')}` `port` must be an integer")
                elif port < 0 or port > 65535:
                    self.error(obj.relpath, f"system RADIUS server `{obj.data.get('name')}` `port` must be between 0 and 65535")

            timeout = obj.data.get("timeout")
            if timeout is not None:
                if not isinstance(timeout, int):
                    self.error(obj.relpath, f"system RADIUS server `{obj.data.get('name')}` `timeout` must be an integer")
                elif timeout < 1 or timeout > 60:
                    self.error(obj.relpath, f"system RADIUS server `{obj.data.get('name')}` `timeout` must be between 1 and 60")

            update_secret = obj.data.get("update_secret")
            if update_secret is not None and update_secret not in ("always", "on_create"):
                self.error(obj.relpath, f"system RADIUS server `{obj.data.get('name')}` `update_secret` must be `always` or `on_create`")

            if obj.data.get("update_secret") == "on_create" and obj.data.get("secret") is None:
                self.error(obj.relpath, f"system RADIUS server `{obj.data.get('name')}` uses `update_secret: on_create` without `secret`")

            active_radius_server_names.add(self.fq_name(str(obj.data.get("partition", "Common")), str(obj.data["name"])))

        self.check_duplicates(
            auth_radius_servers,
            lambda obj: ("system_radius_server", obj.data.get("partition", "Common"), obj.data.get("name")),
            "system RADIUS server",
        )

        active_system_auth_sources = []
        for obj in auth_ldap:
            self.require_fields(obj, ["name"])
            if obj.effective_state == "absent":
                continue

            self.require_fields(obj, ["servers"])

            servers = obj.data.get("servers")
            if not isinstance(servers, list) or not servers:
                self.error(obj.relpath, f"system LDAP auth `{obj.data.get('name')}` `servers` must be a non-empty list")
            else:
                for idx, server in enumerate(servers):
                    if not isinstance(server, str) or not server:
                        self.error(obj.relpath, f"system LDAP auth `{obj.data.get('name')}` `servers[{idx}]` must be a non-empty string")

            source_type = obj.data.get("source_type")
            if source_type is not None and source_type not in ("ldap", "active-directory"):
                self.error(obj.relpath, f"system LDAP auth `{obj.data.get('name')}` `source_type` must be `ldap` or `active-directory`")

            scope = obj.data.get("scope")
            if scope is not None and scope not in ("sub", "one", "base"):
                self.error(obj.relpath, f"system LDAP auth `{obj.data.get('name')}` `scope` must be `sub`, `one`, or `base`")

            ssl = obj.data.get("ssl")
            if ssl is not None and ssl not in ("yes", "no", "start-tls"):
                self.error(obj.relpath, f"system LDAP auth `{obj.data.get('name')}` `ssl` must be `yes`, `no`, or `start-tls`")

            for field in ("check_member_attr", "fallback_to_local", "referrals", "use_for_auth", "validate_certs"):
                value = obj.data.get(field)
                if value is not None and not isinstance(value, bool):
                    self.error(obj.relpath, f"system LDAP auth `{obj.data.get('name')}` `{field}` must be a boolean")

            port = obj.data.get("port")
            if port is not None:
                if not isinstance(port, int):
                    self.error(obj.relpath, f"system LDAP auth `{obj.data.get('name')}` `port` must be an integer")
                elif port < 1 or port > 65535:
                    self.error(obj.relpath, f"system LDAP auth `{obj.data.get('name')}` `port` must be between 1 and 65535")

            update_password = obj.data.get("update_password")
            if update_password is not None and update_password not in ("always", "on_create"):
                self.error(obj.relpath, f"system LDAP auth `{obj.data.get('name')}` `update_password` must be `always` or `on_create`")

            if obj.data.get("update_password") == "on_create" and obj.data.get("bind_password") is None:
                self.error(obj.relpath, f"system LDAP auth `{obj.data.get('name')}` uses `update_password: on_create` without `bind_password`")

            if obj.data.get("use_for_auth") is True:
                active_system_auth_sources.append(("ldap", obj))

        self.check_duplicates(auth_ldap, lambda obj: ("system_auth_ldap", obj.data.get("name")), "system LDAP auth")

        active_tacacs_present = [obj for obj in auth_tacacs if obj.effective_state != "absent"]
        if len(active_tacacs_present) > 1:
            self.error(
                active_tacacs_present[1].relpath,
                "system TACACS auth is device-scoped and supports only one active declaration per target BIG-IP",
            )

        for obj in auth_tacacs:
            if obj.effective_state == "absent":
                continue

            self.require_fields(obj, ["servers"])
            servers = obj.data.get("servers")
            if not isinstance(servers, list) or not servers:
                self.error(obj.relpath, "system TACACS auth `servers` must be a non-empty list")
            else:
                for idx, server in enumerate(servers):
                    if isinstance(server, str):
                        self.validate_ip_like(obj.relpath, server, f"system TACACS auth `servers[{idx}]`")
                    elif isinstance(server, dict):
                        if not server.get("address"):
                            self.error(obj.relpath, f"system TACACS auth `servers[{idx}]` must define `address`")
                        else:
                            self.validate_ip_like(obj.relpath, server.get("address"), f"system TACACS auth `servers[{idx}].address`")
                        if server.get("port") is not None:
                            port = server.get("port")
                            if not isinstance(port, int):
                                self.error(obj.relpath, f"system TACACS auth `servers[{idx}].port` must be an integer")
                            elif port < 0 or port > 65535:
                                self.error(obj.relpath, f"system TACACS auth `servers[{idx}].port` must be between 0 and 65535")
                    else:
                        self.error(obj.relpath, f"system TACACS auth `servers[{idx}]` must be a string or mapping")

            authentication = obj.data.get("authentication")
            if authentication is not None and authentication not in ("use-first-server", "use-all-servers"):
                self.error(obj.relpath, "`authentication` must be `use-first-server` or `use-all-servers`")

            accounting = obj.data.get("accounting")
            if accounting is not None and accounting not in ("send-to-first-server", "send-to-all-servers"):
                self.error(obj.relpath, "`accounting` must be `send-to-first-server` or `send-to-all-servers`")

            protocol_name = obj.data.get("protocol_name")
            if protocol_name is not None and protocol_name not in (
                "lcp", "ip", "ipx", "atalk", "vines", "lat", "xremote", "tn3270",
                "telnet", "rlogin", "pad", "vpdn", "ftp", "http", "deccp", "osicp", "unknown",
            ):
                self.error(obj.relpath, f"system TACACS auth `protocol_name` `{protocol_name}` is not supported")

            service_name = obj.data.get("service_name")
            if service_name is not None and service_name not in (
                "slip", "ppp", "arap", "shell", "tty-daemon", "connection", "system", "firewall",
            ):
                self.error(obj.relpath, f"system TACACS auth `service_name` `{service_name}` is not supported")

            update_secret = obj.data.get("update_secret")
            if update_secret is not None and update_secret not in ("always", "on_create"):
                self.error(obj.relpath, "system TACACS auth `update_secret` must be `always` or `on_create`")

            if obj.data.get("update_secret") == "on_create" and obj.data.get("secret") is None:
                self.error(obj.relpath, "system TACACS auth uses `update_secret: on_create` without `secret`")

            use_for_auth = obj.data.get("use_for_auth")
            if use_for_auth is not None and not isinstance(use_for_auth, bool):
                self.error(obj.relpath, "system TACACS auth `use_for_auth` must be a boolean")
            if use_for_auth is True:
                active_system_auth_sources.append(("tacacs", obj))

        active_radius_present = [obj for obj in auth_radius if obj.effective_state != "absent"]
        if len(active_radius_present) > 1:
            self.error(
                active_radius_present[1].relpath,
                "system RADIUS auth is device-scoped and supports only one active declaration per target BIG-IP",
            )

        for obj in auth_radius:
            if obj.effective_state == "absent":
                continue

            self.require_fields(obj, ["servers"])
            servers = obj.data.get("servers")
            if not isinstance(servers, list) or not servers:
                self.error(obj.relpath, "system RADIUS auth `servers` must be a non-empty list")
            else:
                for idx, server in enumerate(servers):
                    if not isinstance(server, str) or not server:
                        self.error(obj.relpath, f"system RADIUS auth `servers[{idx}]` must be a non-empty string")
                        continue
                    normalized_server = server if server.startswith("/") else self.fq_name("Common", server)
                    if normalized_server not in active_radius_server_names:
                        self.error(obj.relpath, f"system RADIUS auth references undefined RADIUS server `{normalized_server}`")

            retries = obj.data.get("retries")
            if retries is not None:
                if not isinstance(retries, int):
                    self.error(obj.relpath, "system RADIUS auth `retries` must be an integer")
                elif retries < 0:
                    self.error(obj.relpath, "system RADIUS auth `retries` must be zero or greater")

            service_type = obj.data.get("service_type")
            if service_type is not None and service_type not in (
                "authenticate-only", "login", "default", "framed", "callback-login", "callback-framed",
                "outbound", "administrative", "nas-prompt", "callback-nas-prompt", "call-check",
                "callback-administrative",
            ):
                self.error(obj.relpath, f"system RADIUS auth `service_type` `{service_type}` is not supported")

            for field in ("accounting_bug", "fallback_to_local", "use_for_auth"):
                value = obj.data.get(field)
                if value is not None and not isinstance(value, bool):
                    self.error(obj.relpath, f"system RADIUS auth `{field}` must be a boolean")

            if obj.data.get("use_for_auth") is True:
                active_system_auth_sources.append(("radius", obj))

        if len(active_system_auth_sources) > 1:
            _, conflicting_obj = active_system_auth_sources[1]
            active_types = ", ".join(sorted(auth_type for auth_type, _ in active_system_auth_sources))
            self.error(
                conflicting_obj.relpath,
                f"only one management-plane auth source can set `use_for_auth: true` on a target BIG-IP; found {active_types}",
            )

        active_login_banners = [obj for obj in login_banners if obj.effective_state != "absent"]
        if len(active_login_banners) > 1:
            self.error(
                active_login_banners[1].relpath,
                "system login banner is device-scoped and supports only one active declaration per target BIG-IP",
            )

        for obj in login_banners:
            enabled = obj.data.get("enabled")
            if enabled is not None and not isinstance(enabled, bool):
                self.error(obj.relpath, "system login banner `enabled` must be a boolean")
            if obj.effective_state != "absent" and obj.data.get("enabled", True) and obj.data.get("text") in (None, ""):
                self.error(obj.relpath, "system login banner with `enabled: true` must define non-empty `text`")
            text = obj.data.get("text")
            if text is not None and not isinstance(text, str):
                self.error(obj.relpath, "system login banner `text` must be a string")

        for obj in config:
            if "save" in obj.data and not isinstance(obj.data.get("save"), bool):
                self.error(obj.relpath, "`save` must be a boolean")

    def validate_ha(self) -> None:
        trusts = self.objects.get("ha_device_trusts", [])
        groups = self.objects.get("ha_device_groups", [])
        members = self.objects.get("ha_device_group_members", [])
        traffic_groups = self.objects.get("ha_traffic_groups", [])
        device_connectivity = self.objects.get("ha_device_connectivity", [])
        ha_groups = self.objects.get("ha_groups", [])
        configsync_actions = self.objects.get("ha_configsync_actions", [])

        active_group_names = set()
        active_ha_group_names = set()

        active_device_connectivity = [obj for obj in device_connectivity if obj.effective_state != "absent"]
        if len(active_device_connectivity) > 1:
            self.error(
                active_device_connectivity[1].relpath,
                "HA device connectivity is device-local and supports only one active declaration per target BIG-IP",
            )

        for obj in device_connectivity:
            if obj.from_deletions:
                self.error(obj.relpath, "HA device connectivity does not support deletion trees; use desired replacement values instead")
            if obj.effective_state == "absent":
                self.error(obj.relpath, "HA device connectivity does not support `state: absent`")

            if not any(
                obj.data.get(field) is not None
                for field in (
                    "config_sync_ip",
                    "mirror_primary_address",
                    "mirror_secondary_address",
                    "unicast_failover",
                    "failover_multicast",
                    "multicast_interface",
                    "multicast_address",
                    "multicast_port",
                    "cluster_mirroring",
                )
            ):
                self.error(obj.relpath, "HA device connectivity must define at least one managed field")

            for field in ("config_sync_ip", "mirror_primary_address", "mirror_secondary_address"):
                value = obj.data.get(field)
                if value is not None:
                    self.validate_ip_like(obj.relpath, value, f"HA device connectivity `{field}`")

            cluster_mirroring = obj.data.get("cluster_mirroring")
            if cluster_mirroring is not None and cluster_mirroring not in ("between-clusters", "within-cluster"):
                self.error(obj.relpath, "`cluster_mirroring` must be `between-clusters` or `within-cluster`")

            failover_multicast = obj.data.get("failover_multicast")
            if failover_multicast is not None and not isinstance(failover_multicast, bool):
                self.error(obj.relpath, "`failover_multicast` must be a boolean")

            multicast_address = obj.data.get("multicast_address")
            if multicast_address is not None:
                self.validate_ip_like(obj.relpath, multicast_address, "HA device connectivity `multicast_address`")

            multicast_port = obj.data.get("multicast_port")
            if multicast_port is not None:
                if not isinstance(multicast_port, int):
                    self.error(obj.relpath, "`multicast_port` must be an integer")
                elif multicast_port < 0 or multicast_port > 65535:
                    self.error(obj.relpath, "`multicast_port` must be between 0 and 65535")

            unicast_failover = obj.data.get("unicast_failover")
            if unicast_failover is not None:
                if not isinstance(unicast_failover, list):
                    self.error(obj.relpath, "`unicast_failover` must be a list")
                else:
                    for idx, entry in enumerate(unicast_failover):
                        if not isinstance(entry, dict):
                            self.error(obj.relpath, f"`unicast_failover[{idx}]` must be a mapping")
                            continue
                        if not entry.get("address"):
                            self.error(obj.relpath, f"`unicast_failover[{idx}]` must define `address`")
                        else:
                            self.validate_ip_like(
                                obj.relpath,
                                entry.get("address"),
                                f"HA device connectivity `unicast_failover[{idx}].address`",
                            )
                        port = entry.get("port")
                        if port is not None:
                            if not isinstance(port, int):
                                self.error(obj.relpath, f"`unicast_failover[{idx}].port` must be an integer")
                            elif port < 0 or port > 65535:
                                self.error(obj.relpath, f"`unicast_failover[{idx}].port` must be between 0 and 65535")

        for obj in ha_groups:
            self.require_fields(obj, ["name"])
            if obj.effective_state == "absent":
                continue
            active_ha_group_names.add(str(obj.data["name"]))

            active_bonus = obj.data.get("active_bonus")
            if active_bonus is not None:
                if not isinstance(active_bonus, int):
                    self.error(obj.relpath, f"HA group `{obj.data.get('name')}` `active_bonus` must be an integer")
                elif active_bonus < 0:
                    self.error(obj.relpath, f"HA group `{obj.data.get('name')}` `active_bonus` must be zero or greater")

            enable = obj.data.get("enable")
            if enable is not None and not isinstance(enable, bool):
                self.error(obj.relpath, f"HA group `{obj.data.get('name')}` `enable` must be a boolean")

            for field, name_key in (("pools", "pool_name"), ("trunks", "trunk_name")):
                members_list = obj.data.get(field)
                if members_list is None:
                    continue
                if not isinstance(members_list, list):
                    self.error(obj.relpath, f"HA group `{obj.data.get('name')}` `{field}` must be a list")
                    continue
                for idx, member in enumerate(members_list):
                    if not isinstance(member, dict):
                        self.error(obj.relpath, f"HA group `{obj.data.get('name')}` `{field}[{idx}]` must be a mapping")
                        continue
                    if not member.get(name_key):
                        self.error(obj.relpath, f"HA group `{obj.data.get('name')}` `{field}[{idx}]` must define `{name_key}`")
                    if member.get("weight") is None:
                        self.error(obj.relpath, f"HA group `{obj.data.get('name')}` `{field}[{idx}]` must define `weight`")
                    elif not isinstance(member.get("weight"), int):
                        self.error(obj.relpath, f"HA group `{obj.data.get('name')}` `{field}[{idx}].weight` must be an integer")
                    attribute = member.get("attribute")
                    if attribute is not None and attribute != "percent-up-members":
                        self.error(obj.relpath, f"HA group `{obj.data.get('name')}` `{field}[{idx}].attribute` must be `percent-up-members`")
                    minimum_threshold = member.get("minimum_threshold")
                    if minimum_threshold is not None and not isinstance(minimum_threshold, int):
                        self.error(obj.relpath, f"HA group `{obj.data.get('name')}` `{field}[{idx}].minimum_threshold` must be an integer")

        self.check_duplicates(ha_groups, lambda obj: ("ha_group", obj.data.get("name")), "HA group")

        for obj in trusts:
            self.require_fields(obj, ["peer_server"])
            if obj.data.get("type") not in (None, "peer", "subordinate"):
                self.error(obj.relpath, f"HA device trust `{obj.data.get('peer_server')}` has unsupported `type`")

        self.check_duplicates(
            trusts,
            lambda obj: ("ha_device_trust", obj.data.get("peer_server"), obj.data.get("peer_hostname")),
            "HA device trust",
        )

        for obj in groups:
            self.require_fields(obj, ["name"])
            if obj.effective_state == "absent":
                continue
            active_group_names.add(str(obj.data["name"]))
            if obj.data.get("type") not in (None, "sync-failover", "sync-only"):
                self.error(obj.relpath, f"HA device group `{obj.data.get('name')}` has unsupported `type`")

        self.check_duplicates(groups, lambda obj: ("ha_device_group", obj.data.get("name")), "HA device group")

        for obj in members:
            self.require_fields(obj, ["device_group", "name"])
            if obj.effective_state != "absent" and str(obj.data["device_group"]) not in active_group_names:
                self.error(obj.relpath, f"HA device group member `{obj.data.get('name')}` references undefined device group `{obj.data.get('device_group')}`")

        self.check_duplicates(
            members,
            lambda obj: ("ha_device_group_member", obj.data.get("device_group"), obj.data.get("name")),
            "HA device group member",
        )

        for obj in traffic_groups:
            self.require_fields(obj, ["name"])
            if obj.effective_state == "absent":
                continue
            if obj.data.get("auto_failback_time") is not None and obj.data.get("auto_failback") is None:
                self.error(obj.relpath, f"HA traffic group `{obj.data.get('name')}` sets `auto_failback_time` without `auto_failback`")
            if obj.data.get("ha_group") not in (None, "") and obj.data.get("ha_order") not in (None, ""):
                self.error(obj.relpath, f"HA traffic group `{obj.data.get('name')}` cannot set both `ha_group` and `ha_order`")
            if obj.data.get("ha_group") not in (None, "") and str(obj.data.get("ha_group")) not in active_ha_group_names:
                self.error(obj.relpath, f"HA traffic group `{obj.data.get('name')}` references undefined HA group `{obj.data.get('ha_group')}`")

        self.check_duplicates(
            traffic_groups,
            lambda obj: ("ha_traffic_group", obj.partition, obj.data.get("name")),
            "HA traffic group",
        )

        for obj in configsync_actions:
            self.require_fields(obj, ["device_group"])
            if obj.from_deletions:
                self.error(obj.relpath, "HA config sync actions do not support deletion trees")
            push = bool(obj.data.get("sync_device_to_group"))
            pull = bool(obj.data.get("sync_group_to_device"))
            if push == pull:
                self.error(obj.relpath, "HA config sync action must set exactly one of `sync_device_to_group` or `sync_group_to_device`")
            if str(obj.data.get("device_group")) not in active_group_names:
                self.error(obj.relpath, f"HA config sync action references undefined device group `{obj.data.get('device_group')}`")

    def validate_tls(self) -> None:
        keys = self.objects.get("tls_keys", [])
        certificates = self.objects.get("tls_certificates", [])
        ca_bundles = self.objects.get("tls_ca_bundles", [])
        client_ssl_profiles = self.objects.get("tls_client_ssl_profiles", [])
        server_ssl_profiles = self.objects.get("tls_server_ssl_profiles", [])

        active_key_names = set()
        active_certificate_names = set()
        active_ca_bundle_names = set()

        for obj in keys:
            self.require_fields(obj, ["name"])
            if obj.effective_state != "absent":
                self.require_fields(obj, ["content"])
                active_key_names.add(self.fq_name(obj.partition, str(obj.data["name"])))

        self.check_duplicates(keys, lambda obj: ("tls_key", obj.partition, obj.data.get("name")), "TLS key")

        for obj in certificates:
            self.require_fields(obj, ["name"])
            if obj.effective_state != "absent":
                self.require_fields(obj, ["content"])
                active_certificate_names.add(self.fq_name(obj.partition, str(obj.data["name"])))

        self.check_duplicates(certificates, lambda obj: ("tls_certificate", obj.partition, obj.data.get("name")), "TLS certificate")

        for obj in ca_bundles:
            self.require_fields(obj, ["name"])
            if obj.effective_state != "absent":
                self.require_fields(obj, ["content"])
                active_ca_bundle_names.add(self.fq_name(obj.partition, str(obj.data["name"])))

        self.check_duplicates(ca_bundles, lambda obj: ("tls_ca_bundle", obj.partition, obj.data.get("name")), "TLS CA bundle")

        known_cert_like_names = active_certificate_names | active_ca_bundle_names

        for obj in client_ssl_profiles:
            self.require_fields(obj, ["name"])
            if obj.effective_state == "absent":
                continue
            if obj.data.get("cert_key_chain") is not None and not isinstance(obj.data.get("cert_key_chain"), list):
                self.error(obj.relpath, f"TLS client SSL profile `{obj.data.get('name')}` `cert_key_chain` must be a list")
            for index, chain in enumerate(obj.data.get("cert_key_chain", []) or []):
                if not isinstance(chain, dict):
                    self.error(obj.relpath, f"TLS client SSL profile `{obj.data.get('name')}` cert_key_chain entry {index} must be a mapping")
                    continue
                self.require_fields(chain, ["cert", "key"], obj.relpath, f"TLS client SSL profile `{obj.data.get('name')}` cert_key_chain entry {index}")
                self.validate_named_or_fq_reference(obj.relpath, chain.get("cert"), obj.partition, active_certificate_names, "TLS client SSL certificate")
                self.validate_named_or_fq_reference(obj.relpath, chain.get("key"), obj.partition, active_key_names, "TLS client SSL key")
                if chain.get("chain") is not None:
                    self.validate_named_or_fq_reference(obj.relpath, chain.get("chain"), obj.partition, known_cert_like_names, "TLS client SSL chain")
            if obj.data.get("trusted_cert_authority") is not None:
                self.validate_fq_or_common_reference(obj.relpath, obj.data.get("trusted_cert_authority"), known_cert_like_names, "TLS trusted cert authority")
            if obj.data.get("advertised_cert_authority") is not None:
                self.validate_fq_or_common_reference(obj.relpath, obj.data.get("advertised_cert_authority"), known_cert_like_names, "TLS advertised cert authority")
            if obj.data.get("client_auth_crl") is not None and not isinstance(obj.data.get("client_auth_crl"), str):
                self.error(obj.relpath, f"TLS client SSL profile `{obj.data.get('name')}` `client_auth_crl` must be a string")

        self.check_duplicates(
            client_ssl_profiles,
            lambda obj: ("tls_client_ssl_profile", obj.partition, obj.data.get("name")),
            "TLS client SSL profile",
        )

        for obj in server_ssl_profiles:
            self.require_fields(obj, ["name"])
            if obj.effective_state == "absent":
                continue
            if obj.data.get("certificate") is not None:
                self.validate_named_or_fq_reference(obj.relpath, obj.data.get("certificate"), obj.partition, active_certificate_names, "TLS server SSL certificate")
            if obj.data.get("key") is not None:
                self.validate_named_or_fq_reference(obj.relpath, obj.data.get("key"), obj.partition, active_key_names, "TLS server SSL key")
            if obj.data.get("chain") is not None:
                self.validate_named_or_fq_reference(obj.relpath, obj.data.get("chain"), obj.partition, known_cert_like_names, "TLS server SSL chain")
            if obj.data.get("ca_file") is not None:
                self.validate_fq_or_common_reference(obj.relpath, obj.data.get("ca_file"), known_cert_like_names, "TLS server SSL CA file")

        self.check_duplicates(
            server_ssl_profiles,
            lambda obj: ("tls_server_ssl_profile", obj.partition, obj.data.get("name")),
            "TLS server SSL profile",
        )

    def validate_ltm(self) -> None:
        nodes = self.objects.get("ltm_nodes", [])
        profiles = self.objects.get("ltm_profiles", [])
        pools = self.objects.get("ltm_pools", [])
        monitors = self.objects.get("ltm_monitors", [])
        virtual_servers = self.objects.get("ltm_virtual_servers", [])
        tls_client_ssl_profiles = self.objects.get("tls_client_ssl_profiles", [])
        tls_server_ssl_profiles = self.objects.get("tls_server_ssl_profiles", [])
        network_vlans = self.objects.get("network_vlans", [])
        persistence_profiles = self.objects.get("ltm_persistence_profiles", [])
        irules = self.objects.get("ltm_irules", [])
        data_groups = self.objects.get("ltm_data_groups", [])
        policies = self.objects.get("ltm_policies", [])

        active_node_names = set()
        for obj in nodes:
            self.require_fields(obj, ["name"])
            if obj.effective_state != "absent":
                if not obj.data.get("address") and not obj.data.get("fqdn"):
                    self.error(obj.relpath, f"LTM node `{obj.data.get('name')}` must define either `address` or `fqdn`")
                active_node_names.add(self.fq_name(obj.partition, str(obj.data["name"])))

        self.check_duplicates(nodes, lambda obj: ("ltm_node", obj.partition, obj.data.get("name")), "LTM node")

        active_monitor_names = set()
        for obj in monitors:
            self.require_fields(obj, ["name", "type"])
            active = obj.effective_state != "absent"
            if active:
                active_monitor_names.add(self.fq_name(obj.partition, str(obj.data["name"])))

        self.check_duplicates(monitors, lambda obj: ("ltm_monitor", obj.partition, obj.data.get("name")), "LTM monitor")

        supported_profile_types = {"tcp", "udp", "fastl4", "http", "http2", "oneconnect"}
        active_profile_names = set()
        for obj in tls_client_ssl_profiles + tls_server_ssl_profiles:
            if obj.effective_state != "absent" and obj.data.get("name"):
                active_profile_names.add(self.fq_name(obj.partition, str(obj.data["name"])))

        for obj in profiles:
            self.require_fields(obj, ["name", "type"])
            if obj.effective_state == "absent":
                continue
            profile_type = str(obj.data.get("type"))
            if profile_type not in supported_profile_types:
                self.error(
                    obj.relpath,
                    f"LTM profile `{obj.data.get('name')}` type `{profile_type}` is unsupported; use one of {sorted(supported_profile_types)}",
                )
                continue
            active_profile_names.add(self.fq_name(obj.partition, str(obj.data["name"])))

        self.check_duplicates(profiles, lambda obj: ("ltm_profile", obj.partition, obj.data.get("name")), "LTM profile")

        active_pool_names = set()

        for obj in pools:
            self.require_fields(obj, ["name"])
            if obj.effective_state == "absent":
                continue

            settings_payload = self.load_settings_payload(obj.source_file.parent / "settings.yml")
            normalized_pool = normalize_ltm_pool(
                obj.data,
                settings_payload.get("ltm_pool_defaults", {}),
                settings_payload.get("ltm_member_defaults", {}),
                settings_payload.get("ltm_monitor_sets", {}),
            )

            active_pool_names.add(self.fq_name(obj.partition, str(normalized_pool["name"])))

            monitors_list = normalized_pool.get("monitors", [])
            if monitors_list is not None and not isinstance(monitors_list, list):
                self.error(obj.relpath, f"LTM pool `{normalized_pool.get('name')}` `monitors` must be a list")
            else:
                for monitor in monitors_list or []:
                    self.validate_monitor_reference(
                        source=obj.relpath,
                        reference=monitor,
                        known_monitors=active_monitor_names,
                        kind="LTM pool monitor",
                    )

            self.validate_ltm_pool_members(obj.relpath, normalized_pool.get("name"), obj.partition, normalized_pool.get("members"), active_node_names)

        self.check_duplicates(pools, lambda obj: ("ltm_pool", obj.partition, obj.data.get("name")), "LTM pool")

        active_vlan_names = set()
        for obj in network_vlans:
            if obj.effective_state != "absent" and obj.data.get("name"):
                active_vlan_names.add(self.fq_name(obj.partition, str(obj.data["name"])))

        for obj in virtual_servers:
            self.require_fields(obj, ["name"])
            if obj.effective_state == "absent":
                continue

            self.require_fields(obj, ["destination", "destination_port", "pool"])
            profiles = obj.data.get("profiles")
            if profiles is not None:
                if not isinstance(profiles, list):
                    self.error(obj.relpath, f"virtual server `{obj.data.get('name')}` `profiles` must be a list")
                else:
                    for profile_reference in profiles:
                        self.validate_profile_reference(
                            source=obj.relpath,
                            reference=profile_reference,
                            default_partition=obj.partition,
                            known_profiles=active_profile_names,
                            kind="LTM virtual server profile",
                        )
            vs_vlans = obj.data.get("vlans")
            if vs_vlans is not None:
                if not isinstance(vs_vlans, list):
                    self.error(obj.relpath, f"virtual server `{obj.data.get('name')}` `vlans` must be a list")
                else:
                    for vlan in vs_vlans:
                        self.validate_named_or_fq_reference(
                            obj.relpath,
                            vlan,
                            obj.partition,
                            active_vlan_names,
                            "virtual server VLAN",
                        )
            vs_metadata = obj.data.get("metadata")
            if vs_metadata is not None and not isinstance(vs_metadata, list):
                self.error(obj.relpath, f"virtual server `{obj.data.get('name')}` `metadata` must be a list")
            log_profiles = obj.data.get("log_profiles")
            if log_profiles is not None and not isinstance(log_profiles, list):
                self.error(obj.relpath, f"virtual server `{obj.data.get('name')}` `log_profiles` must be a list")
            vlans_enabled = obj.data.get("vlans_enabled")
            if vlans_enabled is not None and not isinstance(vlans_enabled, bool):
                self.error(obj.relpath, f"virtual server `{obj.data.get('name')}` `vlans_enabled` must be a boolean")
            pool = obj.data.get("pool")
            if isinstance(pool, str):
                pool_ref = self.normalize_pool_reference(pool, obj.partition)
                if pool_ref not in active_pool_names:
                    self.error(obj.relpath, f"virtual server `{obj.data.get('name')}` references undefined pool `{pool_ref}`")
                continue
            if not isinstance(pool, dict):
                self.error(obj.relpath, f"virtual server `{obj.data.get('name')}` pool must be a string reference or embedded pool mapping")
                continue

            settings_payload = self.load_settings_payload(obj.source_file.parent / "settings.yml")
            compiled_service = compile_ltm_virtual_server_intent(
                obj.data,
                settings_payload.get("ltm_pool_defaults", {}),
                settings_payload.get("ltm_member_defaults", {}),
                settings_payload.get("ltm_monitor_sets", {}),
            )
            normalized_pool = (compiled_service.get("pools") or [None])[0]
            if normalized_pool is None or not normalized_pool.get("name"):
                self.error(obj.relpath, f"virtual server `{obj.data.get('name')}` embedded pool must define `name`")
                continue

            pool_partition = str(normalized_pool.get("partition", obj.partition))
            active_pool_names.add(self.fq_name(pool_partition, str(normalized_pool["name"])))

            monitors_list = normalized_pool.get("monitors", [])
            if monitors_list is not None and not isinstance(monitors_list, list):
                self.error(obj.relpath, f"LTM pool `{normalized_pool.get('name')}` `monitors` must be a list")
            else:
                for monitor in monitors_list or []:
                    self.validate_monitor_reference(
                        source=obj.relpath,
                        reference=monitor,
                        known_monitors=active_monitor_names,
                        kind="LTM pool monitor",
                    )

            self.validate_ltm_pool_members(
                obj.relpath,
                normalized_pool.get("name"),
                pool_partition,
                normalized_pool.get("members"),
                active_node_names,
            )

        self.check_duplicates(
            virtual_servers,
            lambda obj: ("ltm_virtual_server", obj.partition, obj.data.get("name")),
            "LTM virtual server",
        )

        supported_persistence_types = {"cookie", "source_addr", "universal"}
        active_persistence_names = set()
        for obj in persistence_profiles:
            self.require_fields(obj, ["name", "type"])
            if obj.effective_state == "absent":
                continue
            ptype = str(obj.data.get("type"))
            if ptype not in supported_persistence_types:
                self.error(
                    obj.relpath,
                    f"LTM persistence profile `{obj.data.get('name')}` type `{ptype}` is unsupported; use one of {sorted(supported_persistence_types)}",
                )
            active_persistence_names.add(self.fq_name(obj.partition, str(obj.data["name"])))

        self.check_duplicates(
