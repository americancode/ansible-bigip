            "OWA Exchange 2007 (http)", "SharePoint 2007 (https)",
            "SharePoint 2007 (http)", "Drupal", "Joomla", "Wordpress",
        }

        active_policy_names = set()
        for obj in policies:
            self.require_fields(obj, ["name"])
            if obj.effective_state != "absent":
                if obj.partition != "Common":
                    self.error(obj.relpath, f"WAF policy `{obj.data.get('name')}` must use partition `Common`; the current runtime tasks do not consume a partition field")
                active_policy_names.add(self.fq_name(obj.partition, str(obj.data["name"])))
                template = obj.data.get("template")
                if template is not None and template not in supported_templates:
                    self.error(obj.relpath, f"WAF policy `{obj.data.get('name')}` template `{template}` is not a supported built-in template")
                active = obj.data.get("active")
                if active is not None and not isinstance(active, bool):
                    self.error(obj.relpath, f"WAF policy `{obj.data.get('name')}` `active` must be a boolean")
                apply = obj.data.get("apply")
                if apply is not None and not isinstance(apply, bool):
                    self.error(obj.relpath, f"WAF policy `{obj.data.get('name')}` `apply` must be a boolean")

        self.check_duplicates(
            policies,
            lambda obj: ("waf_policy", obj.partition, obj.data.get("name")),
            "WAF policy",
        )

        for obj in server_technologies:
            self.require_fields(obj, ["name", "policy_name"])
            if obj.effective_state == "absent":
                continue
            if obj.partition != "Common":
                self.error(obj.relpath, f"WAF server technology `{obj.data.get('name')}` must use partition `Common`; the current runtime tasks do not consume a partition field")
            fq_policy = obj.data["policy_name"] if str(obj.data["policy_name"]).startswith("/") else self.fq_name(obj.partition, str(obj.data["policy_name"]))
            if fq_policy not in active_policy_names:
                self.error(obj.relpath, f"WAF server technology `{obj.data.get('name')}` references undefined policy `{fq_policy}`")

        self.check_duplicates(
            server_technologies,
            lambda obj: ("waf_server_technology", obj.data.get("policy_name"), obj.data.get("name")),
            "WAF server technology",
        )

    def validate_apm(self) -> None:
        acls = self.objects.get("apm_acls", [])
        auth_servers = self.objects.get("apm_auth_servers", [])
        sso_configs = self.objects.get("apm_sso_configs", [])
        resources = self.objects.get("apm_resources", [])
        policy_nodes = self.objects.get("apm_policy_nodes", [])
        access_profiles = self.objects.get("apm_access_profiles", [])
        per_session_policies = self.objects.get("apm_per_session_policies", [])
        macros = self.objects.get("apm_macros", [])

        active_auth_server_names = set()
        supported_auth_types = {
            "active_directory", "ldap", "radius", "tacacs",
            "rsa_securid", "cert", "localdb", "saml", "oauth",
        }

        for obj in auth_servers:
            self.require_fields(obj, ["name", "type"])
            if obj.effective_state == "absent":
                continue
            auth_type = obj.data.get("type")
            if auth_type not in supported_auth_types:
                self.error(obj.relpath, f"APM auth server `{obj.data.get('name')}` `type` must be one of {sorted(supported_auth_types)}")
            if auth_type in ("active_directory", "ldap"):
                for field in ("servers", "bind_dn", "bind_pw"):
                    if not obj.data.get(field):
                        self.error(obj.relpath, f"APM auth server `{obj.data.get('name')}` of type `{auth_type}` must define `{field}`")
                if auth_type == "active_directory" and not obj.data.get("domain"):
                    self.error(obj.relpath, f"APM auth server `{obj.data.get('name')}` of type `active_directory` must define `domain`")
            elif auth_type == "radius":
                for field in ("servers", "secret"):
                    if not obj.data.get(field):
                        self.error(obj.relpath, f"APM auth server `{obj.data.get('name')}` of type `radius` must define `{field}`")
                proto = obj.data.get("protocol")
                if proto is not None and proto not in ("pap", "chap", "mschapv2"):
                    self.error(obj.relpath, f"APM auth server `{obj.data.get('name')}` `protocol` must be pap, chap, or mschapv2")
            elif auth_type == "tacacs":
                for field in ("servers", "secret"):
                    if not obj.data.get(field):
                        self.error(obj.relpath, f"APM auth server `{obj.data.get('name')}` of type `tacacs` must define `{field}`")
            elif auth_type == "rsa_securid":
                for field in ("servers", "config_file"):
                    if not obj.data.get(field):
                        self.error(obj.relpath, f"APM auth server `{obj.data.get('name')}` of type `rsa_securid` must define `{field}`")
            elif auth_type == "cert":
                if not obj.data.get("ca_bundle"):
                    self.error(obj.relpath, f"APM auth server `{obj.data.get('name')}` of type `cert` must define `ca_bundle`")
            elif auth_type == "localdb":
                if not obj.data.get("user_source"):
                    self.error(obj.relpath, f"APM auth server `{obj.data.get('name')}` of type `localdb` must define `user_source`")
            elif auth_type == "saml":
                for field in ("idp_metadata_url", "sp_entity_id", "acs_url"):
                    if not obj.data.get(field):
                        self.error(obj.relpath, f"APM auth server `{obj.data.get('name')}` of type `saml` must define `{field}`")
            elif auth_type == "oauth":
                for field in ("provider_url", "client_id", "client_secret", "scopes"):
                    if not obj.data.get(field):
                        self.error(obj.relpath, f"APM auth server `{obj.data.get('name')}` of type `oauth` must define `{field}`")

            servers = obj.data.get("servers")
            if servers is not None:
                if not isinstance(servers, list):
                    self.error(obj.relpath, f"APM auth server `{obj.data.get('name')}` `servers` must be a list")
                else:
                    for idx, server in enumerate(servers):
                        if not isinstance(server, str):
                            self.error(obj.relpath, f"APM auth server `{obj.data.get('name')}` `servers[{idx}]` must be a string")
            encryption = obj.data.get("encryption")
            if encryption is not None and encryption not in ("none", "ssl", "starttls"):
                self.error(obj.relpath, f"APM auth server `{obj.data.get('name')}` `encryption` must be one of none, ssl, starttls")
            active_auth_server_names.add(self.fq_name(obj.partition, str(obj.data["name"])))

        self.check_duplicates(
            auth_servers,
            lambda obj: ("apm_auth_server", obj.partition, obj.data.get("name")),
            "APM auth server",
        )

        active_sso_names = set()
        supported_sso_types = {
            "kerberos", "form_based", "http_basic", "ntlm",
            "saml", "oauth", "citrix", "domain_join",
        }

        for obj in sso_configs:
            self.require_fields(obj, ["name", "type"])
            if obj.effective_state == "absent":
                continue
            sso_type = obj.data.get("type")
            if sso_type not in supported_sso_types:
                self.error(obj.relpath, f"APM SSO config `{obj.data.get('name')}` `type` must be one of {sorted(supported_sso_types)}")
            if sso_type == "kerberos":
                for field in ("keytab", "spn"):
                    if not obj.data.get(field):
                        self.error(obj.relpath, f"APM SSO config `{obj.data.get('name')}` of type `kerberos` must define `{field}`")
                method = obj.data.get("method")
                if method is not None and method not in ("kcd", "negotiate"):
                    self.error(obj.relpath, f"APM SSO config `{obj.data.get('name')}` `method` must be kcd or negotiate")
            elif sso_type == "form_based":
                for field in ("form_action_url", "username_field", "password_field"):
                    if not obj.data.get(field):
                        self.error(obj.relpath, f"APM SSO config `{obj.data.get('name')}` of type `form_based` must define `{field}`")
            elif sso_type == "ntlm":
                for field in ("server", "domain"):
                    if not obj.data.get(field):
                        self.error(obj.relpath, f"APM SSO config `{obj.data.get('name')}` of type `ntlm` must define `{field}`")
            elif sso_type == "saml":
                for field in ("idp_metadata_url", "sp_entity_id", "assertion_consumer_url"):
                    if not obj.data.get(field):
                        self.error(obj.relpath, f"APM SSO config `{obj.data.get('name')}` of type `saml` must define `{field}`")
            elif sso_type == "oauth":
                for field in ("provider_url", "client_id", "client_secret", "scopes"):
                    if not obj.data.get(field):
                        self.error(obj.relpath, f"APM SSO config `{obj.data.get('name')}` of type `oauth` must define `{field}`")
            active_sso_names.add(self.fq_name(obj.partition, str(obj.data["name"])))

        self.check_duplicates(
            sso_configs,
            lambda obj: ("apm_sso_config", obj.partition, obj.data.get("name")),
            "APM SSO config",
        )

        active_resource_names = set()
        supported_resource_types = {"network_access", "webtop", "remote_desktop", "portal_access"}

        for obj in resources:
            self.require_fields(obj, ["name"])
            if obj.effective_state == "absent":
                continue
            resource_type = obj.data.get("type")
            if resource_type is not None and resource_type not in supported_resource_types:
                self.error(obj.relpath, f"APM resource `{obj.data.get('name')}` `type` must be one of {sorted(supported_resource_types)}")
            if resource_type == "network_access":
                address_spaces = obj.data.get("address_spaces")
                if address_spaces is not None:
                    if not isinstance(address_spaces, list):
                        self.error(obj.relpath, f"APM resource `{obj.data.get('name')}` `address_spaces` must be a list")
                    else:
                        for idx, space in enumerate(address_spaces):
                            if not isinstance(space, dict) or "subnet" not in space:
                                self.error(obj.relpath, f"APM resource `{obj.data.get('name')}` `address_spaces[{idx}]` must define `subnet`")
                excluded_subnets = obj.data.get("excluded_subnets")
                if excluded_subnets is not None:
                    if not isinstance(excluded_subnets, list):
                        self.error(obj.relpath, f"APM resource `{obj.data.get('name')}` `excluded_subnets` must be a list")
                    else:
                        for idx, subnet in enumerate(excluded_subnets):
                            if not isinstance(subnet, dict) or "subnet" not in subnet:
                                self.error(obj.relpath, f"APM resource `{obj.data.get('name')}` `excluded_subnets[{idx}]` must define `subnet`")
            if resource_type == "webtop":
                webtop_type = obj.data.get("webtop_type")
                if webtop_type is not None and webtop_type not in ("full", "links"):
                    self.error(obj.relpath, f"APM resource `{obj.data.get('name')}` `webtop_type` must be `full` or `links`")
                items = obj.data.get("items")
                if items is not None:
                    if not isinstance(items, list):
                        self.error(obj.relpath, f"APM resource `{obj.data.get('name')}` `items` must be a list")
                    else:
                        for idx, item_entry in enumerate(items):
                            if not isinstance(item_entry, dict):
                                self.error(obj.relpath, f"APM resource `{obj.data.get('name')}` `items[{idx}]` must be a mapping")
            active_resource_names.add(self.fq_name(obj.partition, str(obj.data["name"])))

        self.check_duplicates(
            resources,
            lambda obj: ("apm_resource", obj.partition, obj.data.get("name")),
            "APM resource",
        )

        active_access_policy_names = set()
        for obj in policy_nodes:
            if obj.effective_state == "absent":
                continue
            policy_name = obj.data.get("policy")
            if policy_name:
                active_access_policy_names.add(self.fq_name(obj.partition, str(policy_name)))

        active_per_session_policy_names = set()
        for obj in per_session_policies:
            if obj.effective_state == "absent":
                continue
            policy_name = obj.data.get("name")
            if policy_name:
                active_per_session_policy_names.add(self.fq_name(obj.partition, str(policy_name)))

        for obj in access_profiles:
            self.require_fields(obj, ["name"])
            if obj.effective_state == "absent":
                continue
            for field in ("default_access_policy", "default_per_session_policy", "sso_configuration", "domain"):
                value = obj.data.get(field)
                if value is not None and not isinstance(value, str):
                    self.error(obj.relpath, f"APM access profile `{obj.data.get('name')}` `{field}` must be a string")

            for field in ("agent_cap", "cookie_fallback"):
                value = obj.data.get(field)
                if value is not None and not isinstance(value, bool):
                    self.error(obj.relpath, f"APM access profile `{obj.data.get('name')}` `{field}` must be a boolean")

            for field in ("session_timeout", "idle_timeout", "max_sessions"):
                value = obj.data.get(field)
                if value is not None:
                    if not isinstance(value, int):
                        self.error(obj.relpath, f"APM access profile `{obj.data.get('name')}` `{field}` must be an integer")
                    elif value < 0:
                        self.error(obj.relpath, f"APM access profile `{obj.data.get('name')}` `{field}` must be zero or greater")

            access_policy_ref = obj.data.get("default_access_policy")
            if isinstance(access_policy_ref, str) and access_policy_ref and not access_policy_ref.startswith("/"):
                fq_access_policy = self.fq_name(obj.partition, access_policy_ref)
                if fq_access_policy not in active_access_policy_names:
                    self.error(obj.relpath, f"APM access profile `{obj.data.get('name')}` references undefined access policy `{fq_access_policy}`")

            per_session_ref = obj.data.get("default_per_session_policy")
            if isinstance(per_session_ref, str) and per_session_ref and not per_session_ref.startswith("/"):
                fq_per_session = self.fq_name(obj.partition, per_session_ref)
                if fq_per_session not in active_per_session_policy_names:
                    self.error(obj.relpath, f"APM access profile `{obj.data.get('name')}` references undefined per-session policy `{fq_per_session}`")

            sso_ref = obj.data.get("sso_configuration")
            if isinstance(sso_ref, str) and sso_ref and not sso_ref.startswith("/"):
                fq_sso = self.fq_name(obj.partition, sso_ref)
                if fq_sso not in active_sso_names:
                    self.error(obj.relpath, f"APM access profile `{obj.data.get('name')}` references undefined SSO config `{fq_sso}`")

        self.check_duplicates(
            access_profiles,
            lambda obj: ("apm_access_profile", obj.partition, obj.data.get("name")),
            "APM access profile",
        )

        for obj in per_session_policies:
            self.require_fields(obj, ["name"])
            if obj.effective_state == "absent":
                continue
            nodes = obj.data.get("nodes")
            if nodes is not None:
                if not isinstance(nodes, list):
                    self.error(obj.relpath, f"APM per-session policy `{obj.data.get('name')}` `nodes` must be a list")
                else:
                    for idx, node in enumerate(nodes):
                        if not isinstance(node, dict):
                            self.error(obj.relpath, f"APM per-session policy `{obj.data.get('name')}` `nodes[{idx}]` must be a mapping")
                        else:
                            if "name" not in node:
                                self.error(obj.relpath, f"APM per-session policy `{obj.data.get('name')}` `nodes[{idx}]` must define `name`")
                            if "type" not in node:
                                self.error(obj.relpath, f"APM per-session policy `{obj.data.get('name')}` `nodes[{idx}]` must define `type`")

        self.check_duplicates(
            per_session_policies,
            lambda obj: ("apm_per_session_policy", obj.partition, obj.data.get("name")),
            "APM per-session policy",
        )

        for obj in macros:
            self.require_fields(obj, ["name"])
            if obj.effective_state == "absent":
                continue
            nodes = obj.data.get("nodes")
            if nodes is not None:
                if not isinstance(nodes, list):
                    self.error(obj.relpath, f"APM macro `{obj.data.get('name')}` `nodes` must be a list")
                else:
                    for idx, node in enumerate(nodes):
                        if not isinstance(node, dict):
                            self.error(obj.relpath, f"APM macro `{obj.data.get('name')}` `nodes[{idx}]` must be a mapping")
                        else:
                            if "name" not in node:
                                self.error(obj.relpath, f"APM macro `{obj.data.get('name')}` `nodes[{idx}]` must define `name`")
                            if "type" not in node:
                                self.error(obj.relpath, f"APM macro `{obj.data.get('name')}` `nodes[{idx}]` must define `type`")

        self.check_duplicates(
            macros,
            lambda obj: ("apm_macro", obj.partition, obj.data.get("name")),
            "APM macro",
        )

        supported_node_types = {
            "logon_page", "ad_auth", "ldap_auth", "kerberos_auth",
            "kcd_sso", "branch", "allow", "deny", "fallback",
            "macro", "variable_assign", "ad_query",
        }
        sso_ref_keys = {"kerberos_sso_object", "sso_config", "saml_sso", "oauth_sso", "form_based_sso", "http_basic_sso", "ntlm_sso"}

        for obj in policy_nodes:
            self.require_fields(obj, ["name", "policy"])
            if obj.effective_state == "absent":
                continue
            node_type = obj.data.get("type")
            if node_type is not None and node_type not in supported_node_types:
                self.error(obj.relpath, f"APM policy node `{obj.data.get('name')}` `type` must be one of {sorted(supported_node_types)}")
            properties = obj.data.get("properties")
            if properties is not None and not isinstance(properties, dict):
                self.error(obj.relpath, f"APM policy node `{obj.data.get('name')}` `properties` must be a mapping")
            if node_type in ("ad_auth", "ad_query") and properties:
                if "ad_server" in properties:
                    ad_ref = properties["ad_server"]
                    fq_ad = ad_ref if str(ad_ref).startswith("/") else self.fq_name(obj.partition, str(ad_ref))
                    if fq_ad not in active_auth_server_names:
                        self.error(obj.relpath, f"APM policy node `{obj.data.get('name')}` references undefined auth server `{fq_ad}`")
            if node_type == "ldap_auth" and properties:
                if "ldap_server" in properties:
                    ldap_ref = properties["ldap_server"]
                    fq_ldap = ldap_ref if str(ldap_ref).startswith("/") else self.fq_name(obj.partition, str(ldap_ref))
                    if fq_ldap not in active_auth_server_names:
                        self.error(obj.relpath, f"APM policy node `{obj.data.get('name')}` references undefined auth server `{fq_ldap}`")
            if node_type in ("kcd_sso", "kerberos_auth") and properties:
                for key in sso_ref_keys:
                    if key in properties:
                        sso_ref = properties[key]
                        fq_sso = sso_ref if str(sso_ref).startswith("/") else self.fq_name(obj.partition, str(sso_ref))
                        if fq_sso not in active_sso_names:
                            self.error(obj.relpath, f"APM policy node `{obj.data.get('name')}` references undefined SSO config `{fq_sso}`")
            if node_type == "branch" and properties:
                rules = properties.get("rules")
                if rules is not None:
                    if not isinstance(rules, list):
                        self.error(obj.relpath, f"APM policy node `{obj.data.get('name')}` `properties.rules` must be a list")
                    else:
                        for idx, rule in enumerate(rules):
                            if not isinstance(rule, dict):
                                self.error(obj.relpath, f"APM policy node `{obj.data.get('name')}` `properties.rules[{idx}]` must be a mapping")
                            elif "name" not in rule or "expression" not in rule:
                                self.error(obj.relpath, f"APM policy node `{obj.data.get('name')}` `properties.rules[{idx}]` must define `name` and `expression`")

        self.check_duplicates(
            policy_nodes,
            lambda obj: ("apm_policy_node", obj.partition, obj.data.get("policy"), obj.data.get("name")),
            "APM policy node",
        )

    @staticmethod
    def _topology_record_id(obj: LoadedObject) -> str:
        source = obj.data.get("source", [])
        destination = obj.data.get("destination", [])
        return f"source={source} destination={destination}"

    def validate_topology_members(self, members: list, source: str, context: str) -> None:
        allowed_keys = {"continent", "country", "datacenter", "subnet", "isp", "region", "pool", "negate"}
        for idx, member in enumerate(members):
            if not isinstance(member, dict):
                self.error(source, f"{context} member {idx} must be a mapping")
                continue
            location_keys = {"continent", "country", "datacenter", "subnet", "isp", "region", "pool"}
            used_location_keys = set(member) & location_keys
            if not used_location_keys and "negate" not in member:
                self.error(source, f"{context} member {idx} must define at least one of: {', '.join(sorted(location_keys))}")
            unsupported = set(member) - allowed_keys
            if unsupported:
                self.error(source, f"{context} member {idx} contains unsupported keys: {', '.join(sorted(unsupported))}")

    def validate_gtm_pool_members(
        self,
        *,
        source: str,
        pool_name: Any,
        pool_partition: str,
        members: Any,
        active_server_names: set[str],
        active_monitor_names: set[str],
        active_ltm_virtual_servers: dict[str, dict[str, Any]],
    ) -> None:
        if members is None:
            return
        if not isinstance(members, list):
            self.error(source, f"GTM pool `{pool_name}` members must be a list")
            return
        if not members:
            self.error(source, f"GTM pool `{pool_name}` must define a non-empty `members` list")
            return

        for member_index, member in enumerate(members):
            if not isinstance(member, dict):
                self.error(source, f"GTM pool `{pool_name}` member {member_index} must be a mapping")
                continue
            self.require_fields(member, ["server", "virtual_server"], source, f"GTM member {member_index}")
            self.validate_gtm_member_ltm_reference(
                source=source,
                pool_name=pool_name,
                member_index=member_index,
                pool_partition=pool_partition,
                member=member,
                active_ltm_virtual_servers=active_ltm_virtual_servers,
            )
            if member.get("state") != "absent":
                self.require_fields(member, ["address", "port"], source, f"GTM member {member_index}")
            server_partition = str(member.get("partition", pool_partition))
            server_name = member.get("server")
            if server_name is not None:
                fq_server = self.fq_name(server_partition, str(server_name))
                if fq_server not in active_server_names:
                    self.error(source, f"GTM member `{server_name}` references undefined server `{fq_server}`")
            for monitor in member.get("monitors", []) or []:
                self.validate_monitor_reference(
                    source=source,
                    reference=monitor,
                    known_monitors=active_monitor_names,
                    kind="GTM member monitor",
                )

    def validate_gtm_member_ltm_reference(
        self,
        *,
        source: str,
        pool_name: Any,
        member_index: int,
        pool_partition: str,
        member: dict[str, Any],
        active_ltm_virtual_servers: dict[str, dict[str, Any]],
    ) -> None:
        if member.get("address") not in (None, "") and member.get("port") not in (None, ""):
            return

        ltm_name = member.get("ltm_virtual_server", member.get("virtual_server"))
        if ltm_name in (None, ""):
            return

        ltm_partition = str(member.get("ltm_partition", member.get("partition", pool_partition)))
        fq_ltm_virtual = ltm_name if isinstance(ltm_name, str) and ltm_name.startswith("/") else self.fq_name(ltm_partition, str(ltm_name))
        if fq_ltm_virtual not in active_ltm_virtual_servers:
            self.error(
                source,
                f"GTM pool `{pool_name}` member {member_index} cannot resolve repo-known LTM virtual `{fq_ltm_virtual}`",
            )

    def build_ltm_virtual_server_lookup(self, virtual_servers: list[LoadedObject]) -> dict[str, dict[str, Any]]:
        lookup: dict[str, dict[str, Any]] = {}
        for obj in virtual_servers:
            if obj.effective_state == "absent":
                continue
            name = obj.data.get("name")
            destination = obj.data.get("destination")
            destination_port = obj.data.get("destination_port")
            if name in (None, "") or destination in (None, "") or destination_port in (None, ""):
                continue
            lookup[self.fq_name(obj.partition, str(name))] = {
                "destination": destination,
                "destination_port": destination_port,
            }
        return lookup

    def validate_monitor_reference(
        self,
        *,
        source: str,
        reference: Any,
        known_monitors: set[str],
        kind: str,
    ) -> None:
        if not isinstance(reference, str):
            self.error(source, f"{kind} reference must be a string")
            return
        if not reference.startswith("/"):
            self.error(source, f"{kind} reference `{reference}` must be fully qualified, for example `/Common/name`")
            return
        partition, _, name = reference.strip("/").partition("/")
        if not partition or not name:
            self.error(source, f"{kind} reference `{reference}` is not a valid fully-qualified object name")
            return
        if partition != "Common" and reference not in known_monitors:
            self.error(source, f"{kind} reference `{reference}` does not match a declared custom monitor")
        if partition == "Common" and reference in known_monitors:
            return

    def validate_named_or_fq_reference(
        self,
        source: str,
        reference: Any,
        default_partition: str,
        known_objects: set[str],
        kind: str,
    ) -> None:
        if not isinstance(reference, str):
            self.error(source, f"{kind} reference must be a string")
            return
        fq_reference = reference if reference.startswith("/") else self.fq_name(default_partition, reference)
        if fq_reference not in known_objects:
            self.error(source, f"{kind} reference `{reference}` does not match a declared object")

    def validate_profile_reference(
        self,
        *,
        source: str,
        reference: Any,
        default_partition: str,
        known_profiles: set[str],
        kind: str,
    ) -> None:
        builtin_profile_names = {
            "tcp",
            "udp",
            "fastL4",
            "fasthttp",
            "http",
            "http2",
            "oneconnect",
            "clientssl",
            "serverssl",
        }
        if not isinstance(reference, str):
            self.error(source, f"{kind} reference must be a string")
            return
        if reference.startswith("/Common/"):
            return
        fq_reference = reference if reference.startswith("/") else self.fq_name(default_partition, reference)
        if reference in builtin_profile_names:
            return
        if fq_reference not in known_profiles:
            self.error(source, f"{kind} reference `{reference}` does not match a declared custom profile or a `/Common/...` built-in profile")

    def validate_fq_or_common_reference(
        self,
        source: str,
        reference: Any,
        known_objects: set[str],
        kind: str,
    ) -> None:
        if not isinstance(reference, str):
            self.error(source, f"{kind} reference must be a string")
            return
        if not reference.startswith("/"):
            self.error(source, f"{kind} reference `{reference}` must be fully qualified, for example `/Common/name`")
            return
        if reference.startswith("/Common/") and reference not in known_objects:
            return
        if reference not in known_objects:
            self.error(source, f"{kind} reference `{reference}` does not match a declared object")

    def check_duplicates(
        self,
        objects: list[LoadedObject],
        key_func,
        label: str,
    ) -> None:
        seen: dict[tuple[Any, ...], LoadedObject] = {}
        for obj in objects:
            key = key_func(obj)
            if any(part is None for part in key):
                continue
            if key in seen:
                self.error(obj.relpath, f"{label} `{key[1:]}` duplicates {seen[key].relpath}")
            else:
                seen[key] = obj

    def require_fields(
        self,
        obj: LoadedObject | dict[str, Any],
        fields: list[str],
        source: str | None = None,
        label: str | None = None,
    ) -> None:
        data = obj.data if isinstance(obj, LoadedObject) else obj
        source_ref = obj.relpath if isinstance(obj, LoadedObject) else (source or "<unknown>")
        prefix = label or "object"
        for field in fields:
            if data.get(field) in (None, ""):
                self.error(source_ref, f"{prefix} must define `{field}`")

    def fq_name(self, partition: str, name: str) -> str:
        return f"/{partition}/{name}"

    def normalize_pool_reference(self, reference: str, default_partition: str) -> str:
        if reference.startswith("/"):
            return reference
        return self.fq_name(default_partition, reference)

    def fq_gtm_pool_name(self, partition: str, record_type: str, name: str) -> str:
        return f"/{partition}/{record_type}/{name}"

    def normalize_gtm_pool_reference(self, reference: str, default_partition: str, record_type: str) -> str:
        if reference.startswith("/"):
            parts = reference.strip("/").split("/", 2)
            if len(parts) == 3:
                return reference
            if len(parts) == 2:
                return f"/{parts[0]}/{record_type}/{parts[1]}"
            return f"/{default_partition}/{record_type}/{reference.strip('/')}"
        return self.fq_gtm_pool_name(default_partition, record_type, reference)

    def is_inline_gtm_pool(self, pool: dict[str, Any]) -> bool:
        return "members" in pool or "monitors" in pool or "default_monitors" in pool

    def load_yaml(self, path: Path) -> Any:
        try:
            with path.open("r", encoding="utf-8") as handle:
                return yaml.load(handle, Loader=AnsibleVarLoader) or {}
        except yaml.YAMLError as exc:
            self.error(path, f"failed to parse YAML: {exc}")
            return {}
        except OSError as exc:
            self.error(path, f"failed to read file: {exc}")
            return {}

    def error(self, source: Path | str, message: str) -> None:
        rel = str(source.relative_to(ROOT)) if isinstance(source, Path) else source
        self.errors.append(f"{rel}: {message}")

    def validate_ip_like(self, source: Path | str, value: Any, label: str) -> None:
        if not isinstance(value, str):
            self.error(source, f"{label} must be a string")
            return
        if value == "management-ip":
            return
        try:
            ipaddress.ip_address(value)
        except ValueError:
            self.error(source, f"{label} must be a valid IPv4 or IPv6 address")

    def normalize_route_domain_id(self, value: Any) -> int | None:
        if isinstance(value, int):
            return value
        if isinstance(value, str) and value.isdigit():
            return int(value)
        return None

    def extract_route_domain_id(self, value: Any) -> int | None:
        if not isinstance(value, str):
            return None
        match = re.search(r"%(\d+)$", value)
        if match is None:
            return None
        return int(match.group(1))

    def is_ip_address(self, value: str) -> bool:
        try:
            ipaddress.ip_address(value)
        except ValueError:
            return False
        return True


def main() -> int:
    return Validator().run()


if __name__ == "__main__":
    raise SystemExit(main())
