#!/usr/bin/env python3
"""Import live BIG-IP configuration into repository var tree format.

Queries a BIG-IP device via its REST API and generates YAML files that match
the repository's var tree structure under `vars/`. Output is written to a
target directory for review before committing.

Environment variables:
    F5_HOST         — BIG-IP hostname or IP (required)
    F5_USERNAME     — BIG-IP username (default: admin)
    F5_PASSWORD     — BIG-IP password (required)
    F5_SERVER_PORT  — BIG-IP port (default: 443)

Usage:
    F5_HOST=10.0.0.1 F5_PASSWORD=secret python3 tools/import-from-bigip --out imported/
    F5_HOST=10.0.0.1 F5_PASSWORD=secret python3 tools/import-from-bigip --out imported/ --types ltm_nodes ltm_pools
"""

from __future__ import annotations

import os
import re
import sys
import warnings
from dataclasses import dataclass, field
from pathlib import Path
from typing import Any

import yaml

warnings.filterwarnings("ignore", category=DeprecationWarning)

try:
    import requests
except ImportError:
    print("ERROR: 'requests' package is required. Install with: pip install requests", file=sys.stderr)
    sys.exit(1)


class VarTreeDumper(yaml.Dumper):
    def increase_indent(self, flow=False, *args, **kwargs):
        return super().increase_indent(flow=flow, indentless=False)


def str_representer(dumper: yaml.Dumper, data: str) -> yaml.Node:
    if "\n" in data:
        return dumper.represent_scalar("tag:yaml.org,2002:str", data, style="|")
    return dumper.represent_scalar("tag:yaml.org,2002:str", data)


VarTreeDumper.add_representer(str, str_representer)


@dataclass
class BigIPConnection:
    host: str
    username: str
    password: str
    port: int = 443

    @property
    def base_url(self) -> str:
        return f"https://{self.host}:{self.port}/mgmt/tm"

    @classmethod
    def from_env(cls) -> "BigIPConnection":
        host = os.environ.get("F5_HOST")
        if not host:
            print("ERROR: F5_HOST environment variable is required.", file=sys.stderr)
            sys.exit(1)
        password = os.environ.get("F5_PASSWORD")
        if not password:
            print("ERROR: F5_PASSWORD environment variable is required.", file=sys.stderr)
            sys.exit(1)
        return cls(
            host=host,
            username=os.environ.get("F5_USERNAME") or os.environ.get("F5_USER", "admin"),
            password=password,
            port=int(os.environ.get("F5_SERVER_PORT") or os.environ.get("F5_PORT", "443")),
        )

    def get_all(self, uri: str) -> list[dict[str, Any]]:
        url = f"{self.base_url}/{uri}"
        params = {"$top": 1000}
        items: list[dict[str, Any]] = []
        while url:
            resp = requests.get(url, auth=(self.username, self.password), params=params, verify=False, timeout=30)
            resp.raise_for_status()
            data = resp.json()
            items.extend(data.get("items", []))
            url = data.get("nextSelfLink")
            params = {}
        return items


